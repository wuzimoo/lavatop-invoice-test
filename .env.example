PORT=3000
LAVA_API_BASE=https://gate.lava.top
LAVA_API_KEY=replace_with_your_lava_api_key
LAVA_OFFER_ID=replace_with_your_monthly_offer_id
LAVA_DEFAULT_CURRENCY=USD

# Optional: protect webhook endpoint (recommended for production)
# If set, incoming webhook request must include this header: X-Api-Key: <value>
LAVA_WEBHOOK_API_KEY=

# Optional alternative webhook auth
LAVA_WEBHOOK_BASIC_USER=
LAVA_WEBHOOK_BASIC_PASS=
